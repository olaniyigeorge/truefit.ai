ENV=dev              # dev | staging | prod
PROJECT_NAME=truefit.ai
API_VERSION=v1
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
CLIENT_DOMAIN=http://localhost:5173
BACKEND_DOMAIN=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_SECRET_KEY=change_me_super_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_MODE=jwt                        # jwt | disabled
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/truefit_db
DB_ECHO=false                        # true to log SQL queries in dev
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=truefit
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_LIVE_ENABLED=true             # toggle live interview mode
STORAGE_PROVIDER=local               # local | gcs
LOCAL_STORAGE_DIR=./storage
GCS_BUCKET=your_bucket_name
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json
REALTIME_ENABLED=true
WEBRTC_TOKEN_SECRET=change_me_webrtc_secret
WORKERS_ENABLED=
SENTRY_DSN=